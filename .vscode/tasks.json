{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "make",
            "args": ["clean", "&&", "make"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "detail": "Backend + Frontend derle"
        },
        {
            "label": "Run Visualizer",
            "type": "shell",
            "command": "./visualizer",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Project",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "detail": "Derle ve çalıştır"
        }
    ]
}
